# ── Local inference (automated matrix — no paid calls) ──────────────────────
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_KEY=lm-studio

# ── Baseline source label (operator-collected, not API-called by harness) ───
# Vertex auto-derives from VERTEX_BASELINE_MODEL if unset (see pnpm gemini:models).
# Re-collect after model change: pnpm baseline:collect -- --force
EVAL_BASELINE_SOURCE=vertex-gemini-3-1-pro-preview

# ── Vertex / Gemini baseline (credit-funded text models ONLY) ───────────────
# Run `pnpm gemini:models` against your key — do NOT use TTS/realtime/image ids.
VERTEX_BASELINE_MODEL=gemini-3.1-pro-preview
VERTEX_JUDGE_MODEL=gemini-3.5-flash
GEMINI_API_KEY=

# ── Optional: Azure OpenAI judge (credit-funded ONLY — never direct OpenAI API) ─
# Use a CHAT deployment — NOT gpt-realtime-* (voice/realtime cannot do chat completions).
EVAL_ENABLE_AZURE_JUDGE=false
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Optional: Vertex judge (credit-funded ONLY) ───────────────────────────
EVAL_ENABLE_VERTEX_JUDGE=false
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ── Langfuse OSS (self-hosted, no paid SaaS required) ─────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# DeepEval Confident AI cloud (leave empty — local-only)
CONFIDENT_API_KEY=

# ── Matrix runner ─────────────────────────────────────────────────────────
EVAL_SMOKE_MODELS=liquid/lfm2.5-1.2b,qwen/qwen3.5-9b

# User-judge queue thresholds (deterministic assertion scores, not API judge)
EVAL_USER_JUDGE_REVIEW_ALL=true
EVAL_USE_PROMPTFOO=true
EVAL_BASELINE_COLLECTOR=vertex
EVAL_OPTIMIZATION_INTERVAL_MS=300000